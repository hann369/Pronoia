rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products-app/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /subscribers/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /users/{uid} {
      // Allow reading user profiles and publicKeys to allow user searches and E2E keys loading
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /bookmarks/{bookmarkId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /stacks/{stackId} {
        allow create: if request.auth != null && request.auth.uid == uid;
        allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      }

      match /purchases/{purchaseId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /stack/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /logs/{dateString} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /meta/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /timeline/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Rules for Chat System
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
