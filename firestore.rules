rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the authenticated user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products-app/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /subscribers/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /users/{uid} {
      // Allow reading user profiles and publicKeys to allow user searches and E2E keys loading, or webhook using tempSecret
      allow read: if request.auth != null || 
                   (resource != null && resource.data.profile.tempSecret == 'DEIN_WEBHOOK_SECRET_HIER');
      
      // Allow user to write to their own document, admins to modify any user document, or webhook with valid tempSecret
      allow write: if (request.auth != null && (request.auth.uid == uid || isAdmin())) ||
                    (request.resource.data.profile.tempSecret == 'DEIN_WEBHOOK_SECRET_HIER' || 
                     (resource != null && resource.data.profile.tempSecret == 'DEIN_WEBHOOK_SECRET_HIER'));

      match /bookmarks/{bookmarkId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /stacks/{stackId} {
        allow create: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow read, update, delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /purchases/{purchaseId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /stack/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /logs/{dateString} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /meta/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /timeline/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
    }

    // Rules for Chat System
    match /chats/{chatId} {
      // Allow reading/writing if participant or admin
      allow read, write: if request.auth != null && 
        (request.auth.uid in resource.data.participants || isAdmin());
      
      // Allow creating if participant or admin
      allow create: if request.auth != null && 
        (request.auth.uid in request.resource.data.participants || isAdmin());

      // Rules for Messages subcollection
      match /messages/{messageId} {
        // Allow reading/writing if participant of the parent chat or admin
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || 
          isAdmin()
        );
      }
    }

    // Rules for Friendship / Social System
    match /friendships/{friendshipId} {
      // Allow reading/updating/deleting if participant or admin
      allow read, update, delete: if request.auth != null && 
        (request.auth.uid in resource.data.users || isAdmin());
      
      // Allow creating if participant or admin
      allow create: if request.auth != null && 
        (request.auth.uid in request.resource.data.users || isAdmin());
    }
  }
}
